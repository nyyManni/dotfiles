#!/bin/bash

set -euo pipefail

# Configuration
MONITOR_CONFIG_DIR="$HOME/.config/hypr/monitors"
ACTIVE_CONFIG_LINK="$MONITOR_CONFIG_DIR/active.conf"
DEFAULT_CONFIG="$MONITOR_CONFIG_DIR/default.conf"
LOG_FILE="/tmp/hyprland-workspace-rearrange.log"

# Redirect all output to log file
exec >> "$LOG_FILE" 2>&1

echo "=========================================="
echo "Run started at: $(date '+%Y-%m-%d %H:%M:%S')"
echo "=========================================="
echo ""

# Step 1: Select and symlink the best matching monitor configuration

# Get list of currently connected monitors with their descriptions
declare -A monitor_desc_to_name
declare -a connected_monitor_descs

echo "=== Step 1: Selecting monitor configuration ==="
echo ""
echo "Detecting connected monitors..."
while IFS= read -r line; do
    if [[ "$line" =~ ^Monitor[[:space:]]+([^[:space:]]+)[[:space:]]+\(ID[[:space:]]+[0-9]+\): ]]; then
        current_monitor_name="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^[[:space:]]*description:[[:space:]]*(.+)$ ]]; then
        monitor_desc="${BASH_REMATCH[1]}"
        monitor_desc_to_name["$monitor_desc"]="$current_monitor_name"
        connected_monitor_descs+=("$monitor_desc")
        echo "  Found: $current_monitor_name - $monitor_desc"
    fi
done < <(hyprctl monitors)

if [[ ${#monitor_desc_to_name[@]} -eq 0 ]]; then
    echo "Error: No monitors detected" >&2
    exit 1
fi

# Function to extract unique monitor descriptions from a config file
get_monitors_from_config() {
    local config_file="$1"
    declare -A monitors
    
    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        
        # Match workspace lines with monitor descriptions
        if [[ "$line" =~ monitor:desc:([^,]+) ]]; then
            monitors["${BASH_REMATCH[1]}"]=1
        # Also match plain monitor references (e.g., monitor:eDP-1)
        elif [[ "$line" =~ monitor:([^,[:space:]]+) ]]; then
            monitors["${BASH_REMATCH[1]}"]=1
        fi
    done < "$config_file"
    
    # Output unique monitor names
    for monitor in "${!monitors[@]}"; do
        echo "$monitor"
    done
}

# Find the best matching configuration
echo ""
echo "Searching for matching monitor configuration..."
best_match_config=""

for config_file in "$MONITOR_CONFIG_DIR"/*.conf; do
    # Skip the active.conf symlink and default.conf
    [[ "$(basename "$config_file")" == "active.conf" ]] && continue
    [[ ! -f "$config_file" ]] && continue
    
    config_name="$(basename "$config_file")"
    echo "  Checking $config_name..."
    
    # Get all monitors required by this config
    mapfile -t config_monitors < <(get_monitors_from_config "$config_file")
    
    if [[ ${#config_monitors[@]} -eq 0 ]]; then
        echo "    No monitors defined in config, skipping"
        continue
    fi
    
    # Check if all monitors in the config are connected
    all_monitors_found=true
    for required_monitor in "${config_monitors[@]}"; do
        found=false
        for connected_monitor in "${connected_monitor_descs[@]}"; do
            if [[ "$required_monitor" == "$connected_monitor" ]]; then
                found=true
                break
            fi
        done
        
        # Also check if it's a monitor name like eDP-1
        if [[ -n "${monitor_desc_to_name[$required_monitor]:-}" ]]; then
            found=true
        fi
        
        if [[ "$found" == false ]]; then
            all_monitors_found=false
            echo "    Missing monitor: $required_monitor"
            break
        fi
    done
    
    if [[ "$all_monitors_found" == true ]]; then
        echo "    ✓ All monitors match!"
        best_match_config="$config_file"
        break
    fi
done

# If no match found, use default.conf
if [[ -z "$best_match_config" ]]; then
    echo ""
    echo "No matching configuration found, using default.conf"
    best_match_config="$DEFAULT_CONFIG"
fi

# Create the symlink
selected_config_name="$(basename "$best_match_config")"
echo ""
echo "Symlinking active.conf -> $selected_config_name"
ln -sf "$selected_config_name" "$ACTIVE_CONFIG_LINK"

# Reload Hyprland configuration
echo "Reloading Hyprland configuration..."
hyprctl reload

# Step 2: Rearrange existing workspaces

echo ""
echo "=== Step 2: Rearranging workspaces ==="
echo ""

# Parse workspace-to-monitor assignments from the active config file
declare -A workspace_monitor_map

if [[ ! -f "$ACTIVE_CONFIG_LINK" ]]; then
    echo "Error: Active configuration not found: $ACTIVE_CONFIG_LINK" >&2
    exit 1
fi

echo "Parsing workspace assignments from $ACTIVE_CONFIG_LINK..."
workspace_count=0
while IFS= read -r line; do
    # Skip empty lines and comments
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    
    # Match lines like: workspace = N, monitor:desc:DESCRIPTION[, default:true]
    if [[ "$line" =~ ^[[:space:]]*workspace[[:space:]]*=[[:space:]]*([0-9]+)[[:space:]]*,[[:space:]]*monitor:desc:([^,]+) ]]; then
        workspace_num="${BASH_REMATCH[1]}"
        monitor_desc="${BASH_REMATCH[2]}"
        workspace_monitor_map[$workspace_num]="$monitor_desc"
        echo "  Workspace $workspace_num -> $monitor_desc"
        workspace_count=$((workspace_count + 1))
    fi
done < "$ACTIVE_CONFIG_LINK"

if [[ $workspace_count -eq 0 ]]; then
    echo "Warning: No workspace assignments found in config file"
    echo "Nothing to rearrange, exiting."
    exit 0
fi

# Re-detect monitors after reload (monitor names may have changed)
declare -A monitor_desc_to_name_after_reload

echo ""
echo "Re-detecting monitors after reload..."
while IFS= read -r line; do
    if [[ "$line" =~ ^Monitor[[:space:]]+([^[:space:]]+)[[:space:]]+\(ID[[:space:]]+[0-9]+\): ]]; then
        current_monitor_name="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^[[:space:]]*description:[[:space:]]*(.+)$ ]]; then
        monitor_desc="${BASH_REMATCH[1]}"
        monitor_desc_to_name_after_reload["$monitor_desc"]="$current_monitor_name"
        echo "  Found: $current_monitor_name - $monitor_desc"
    fi
done < <(hyprctl monitors)

# Get list of existing workspaces
echo ""
echo "Moving workspaces to assigned monitors..."
existing_workspaces=$(hyprctl workspaces -j | jq -r '.[].id' | sort -n)

for workspace_id in $existing_workspaces; do
    # Check if this workspace has a monitor assignment
    if [[ -n "${workspace_monitor_map[$workspace_id]:-}" ]]; then
        target_monitor_desc="${workspace_monitor_map[$workspace_id]}"
        
        # Find the monitor name for this description
        if [[ -n "${monitor_desc_to_name_after_reload[$target_monitor_desc]:-}" ]]; then
            target_monitor_name="${monitor_desc_to_name_after_reload[$target_monitor_desc]}"
            echo "  Moving workspace $workspace_id to monitor $target_monitor_name ($target_monitor_desc)"
            hyprctl dispatch moveworkspacetomonitor "$workspace_id" "$target_monitor_name"
        else
            echo "  Warning: Monitor not connected for workspace $workspace_id: $target_monitor_desc"
        fi
    else
        echo "  Skipping workspace $workspace_id (no assignment in config)"
    fi
done

echo ""
echo "Done! Workspaces have been rearranged."
